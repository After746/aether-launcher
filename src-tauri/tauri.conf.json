{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aether Launcher",
  "version": "0.1.0",
  "identifier": "com.aether.launcher",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Aether Launcher",
        "width": 1180,
        "height": 720,
        "minWidth": 940,
        "minHeight": 600,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost data:; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}